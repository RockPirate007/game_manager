{
  "match_reports": {
    "win": [
      {
        "id": "win_dominant",
        "template": "{team} одержал убедительную победу над {opponent} со счётом {score}! {scorer} отметился дублем, а команда показала великолепную игру.",
        "mood": "ecstatic"
      },
      {
        "id": "win_narrow",
        "template": "{team} одержал волевую победу над {opponent} со счётом {score}. {scorer} забил решающий гол на {minute}-й минуте.",
        "mood": "happy"
      },
      {
        "id": "win_comeback",
        "template": "{team} совершил впечатляющий камбэк против {opponent}, проигрывая {losing_score}, но победил {score}! {scorer} стал героем матча.",
        "mood": "ecstatic"
      },
      {
        "id": "win_clean_sheet",
        "template": "{team} одержал сухую победу над {opponent} {score}. Оборона действовала безупречно, а {scorer} забил гол.",
        "mood": "happy"
      }
    ],
    "draw": [
      {
        "id": "draw_high_scoring",
        "template": "{team} сыграл вничью с {opponent} {score} в матче с обилием моментов. {scorer} забил за нашу команду.",
        "mood": "neutral"
      },
      {
        "id": "draw_low_scoring",
        "template": "Ничья {score} между {team} и {opponent}. Обе команды действовали осторожно.",
        "mood": "neutral"
      },
      {
        "id": "draw_late_equalizer",
        "template": "{team} упустил победу против {opponent}. Соперник сравнял счёт на {minute}-й минуте. Итоговый счёт {score}.",
        "mood": "disappointed"
      }
    ],
    "loss": [
      {
        "id": "loss_heavy",
        "template": "{team} потерпел тяжёлое поражение от {opponent} со счётом {score}. Команда не смогла противостоять сопернику.",
        "mood": "furious"
      },
      {
        "id": "loss_narrow",
        "template": "{team} уступил {opponent} со счётом {score}. Гол на {minute}-й минуте оказался решающим.",
        "mood": "disappointed"
      },
      {
        "id": "loss_unlucky",
        "template": "{team} проиграл {opponent} {score} несмотря на доминирование. Незаслуженный результат.",
        "mood": "frustrated"
      }
    ]
  },
  "transfer_news": {
